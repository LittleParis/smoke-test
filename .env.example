# 冒烟测试环境配置
# 复制本文件为 .env 并填入真实值，.env 不会被提交到 git

# 仅允许 demo/test/qa/staging 等测试环境
TEST_ENVIRONMENT=demo
TEST_BASE_URL=https://aftersaleapi.demo.ehi.com.cn
TEST_LOGIN_URL=https://login.demo.ehi.com.cn/Account/Login
TEST_LOGIN_RETURN_URL=https://djeoadmin.demo.ehi.com.cn/
ALLOWED_TEST_HOSTS=aftersaleapi.demo.ehi.com.cn
TEST_PLATFORM=MyEhi
TEST_VERIFY_SSL=false

# 登录凭据
TEST_USERNAME=
TEST_PASSWORD=

# 网关加密（预留，当前未启用）
GATEWAY_KEY=
GATEWAY_IV=

# 企微通知 Webhook（CI 中使用）
WECOM_WEBHOOK=
